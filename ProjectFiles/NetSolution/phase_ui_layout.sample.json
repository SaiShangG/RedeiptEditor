{
  "version": 3,
  "description": "Single-template test layout aligned to UDT_Phase. Two test configs per area.",
  "sections": [
    {
      "id": "ParaPanel1",
      "panelType": "PhaseParasPanel",
      "title": "Phase Parameters Area (Test x2)",
      "rowLayoutPath": "VL/HL",
      "items": [
        {
          "id": "Para0",
          "widgetType": "PhaseSinglePara",
          "bindKey": "Parameter1",
          "bind": {
            "bufferField": "PP.FixedSetPointValue",
            "valueRank": "OneDimension",
            "index": 0,
            "uiProperty": "Text",
            "sourceTagPath": "PP.FixedSetPointValue[0]"
          }
        },
        {
          "id": "Para1",
          "widgetType": "PhaseSinglePara",
          "bindKey": "Parameter2",
          "bind": {
            "bufferField": "PP.ControllerSetPointValue",
            "valueRank": "OneDimension",
            "index": 0,
            "uiProperty": "Text",
            "sourceTagPath": "PP.ControllerSetPointValue[0]"
          }
        }
      ]
    },
    {
      "id": "ParaPanel2",
      "panelType": "PhaseParasPanel",
      "title": "End Conditions Area (Test x2)",
      "rowLayoutPath": "VL/HL",
      "rowLayoutHorizontalGap": 0,
      "items": [
        {
          "id": "ParaRunningTIme",
          "widgetType": "PhaseRunningTime",
          "bindKeySwitch": "EcRunTimeEnabled",
          "bindKeyText": "EcRunTimeHms",
          "bind": {
            "switchField": "EC.EC1Enable",
            "textFields": [
              "EC.RunningTimeHr",
              "EC.RunningTimeMin",
              "EC.RunningTimeSec"
            ],
            "uiPropertySwitch": "Checked",
            "uiPropertyText": "Text"
          }
        },
        {
          "id": "ParaCP1",
          "widgetType": "PhaseParaCompare1",
          "bindKeySwitch": "EcCp1Enabled",
          "bindKeyText": "EcCp1Level",
          "bind": {
            "switchField": "EC.EC1Enable",
            "valueField": "EC.EC1SP",
            "selectorField": "EC.EC1Selected",
            "operatorField": "EC.EC1Operator",
            "uiPropertySwitch": "Checked",
            "uiPropertyText": "Text"
          }
        }
      ]
    },
    {
      "id": "ParaPanel3",
      "panelType": "PhaseParasPanel",
      "title": "Valve/Pump Area (Test x2)",
      "rowLayoutPath": "VL/HL",
      "items": [
        {
          "id": "ValveSetting0",
          "widgetType": "PhaseValvePanel",
          "valveLabel": "Valve[0]",
          "bindKey": "Valve0",
          "bind": {
            "bufferField": "PP.Valve",
            "valueRank": "OneDimension",
            "index": 0,
            "uiProperty": "Checked",
            "sourceTagPath": "PP.Valve[0]"
          }
        },
        {
          "id": "ValveSetting1",
          "widgetType": "PhaseValvePanel",
          "valveLabel": "Pump[0]",
          "bindKey": "Pump0",
          "bind": {
            "bufferField": "PP.Pump",
            "valueRank": "OneDimension",
            "index": 0,
            "uiProperty": "Checked",
            "sourceTagPath": "PP.Pump[0]"
          }
        }
      ]
    }
  ]
}